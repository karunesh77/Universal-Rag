# =====================================================
# ENVIRONMENT VARIABLES - RAG System
# =====================================================
# YE FILE TEMPLATE HAI
# Iska copy banao (.env naam se) aur values fill karo
# KABHI GIT MEIN .env PUSH NAHI KARNA (SECRET INFO HAI)
# =====================================================

# =====================================================
# 1. BACKEND CONFIGURATION
# =====================================================
# Backend kis server par chalega

# Backend ka address (0.0.0.0 = sab network interfaces par accessible)
BACKEND_HOST=0.0.0.0

# Backend ka port number (browser mein: http://localhost:8000)
BACKEND_PORT=8000

# Environment type (development ya production)
# development = auto-reload, detailed errors
# production = optimized, minimal errors
ENVIRONMENT=development

# =====================================================
# 2. DATABASE CONFIGURATION - PostgreSQL
# =====================================================
# Database = jahan par data store hota hai
# PostgreSQL = SQL database (relational database)

# Complete database URL (PostgreSQL connection string)
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
# Ye database table format mein data store karta hai
DATABASE_URL=postgresql://postgres:password@localhost:5432/rag_system

# PostgreSQL username
POSTGRES_USER=postgres

# PostgreSQL password (secure rakhna!)
POSTGRES_PASSWORD=password

# PostgreSQL database name (ye database create hoga)
POSTGRES_DB=rag_system

# =====================================================
# 3. CACHE LAYER - Redis
# =====================================================
# Redis = in-memory cache (bilkul tez)
# Repeated queries ke answers cache mein store ho jate hain
# Database hit nahi hoti = faster response

# Redis connection URL
# localhost:6379 = default Redis address aur port
REDIS_URL=redis://localhost:6379/0

# =====================================================
# 4. AI/LLM API KEYS - SECRET INFORMATION
# =====================================================
# Ye API keys aapke external AI services ke liye hain
# KABHI PUBLIC NAHI KARNA, KABHI GIT MEIN NAHI PUSH KARNA

# OpenAI API Key (text to embedding conversion)
# https://platform.openai.com/api-keys se le sakte ho
# Embedding = text ko numbers mein convert karna (vector bananna)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# Anthropic API Key (Claude AI - answers generate karna)
# https://console.anthropic.com/ se le sakte ho
# Claude = advanced AI model (better answers deta hai)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Pinecone API Key (Vector Database)
# https://pinecone.io se le sakte ho
# Vector Database = embeddings ko store aur search karna
PINECONE_API_KEY=xxxxxxxxxxxxx

# Pinecone Environment
# Pinecone mein alag-alag regions hote hain
# https://pinecone.io mein dekh sakte ho
PINECONE_ENVIRONMENT=gcp-starter

# =====================================================
# 5. FILE UPLOAD CONFIGURATION
# =====================================================
# Users jo documents upload karenge, unke liye settings

# Maximum file size (52428800 bytes = 50 MB)
# Isse bada file upload nahi kar payega user
MAX_FILE_SIZE=52428800

# Upload directory (jahan par files store hongi)
UPLOAD_DIRECTORY=./uploads

# =====================================================
# 6. CORS CONFIGURATION
# =====================================================
# CORS = Kaunsi websites ko API access de

# Frontend addresses (React server kahan par hai)
# Comma-separated values (ek se zyada sites de sakte ho)
# Development: http://localhost:5173 (Vite default)
# Production: https://yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =====================================================
# 7. FRONTEND CONFIGURATION
# =====================================================
# Frontend ke liye variables

# Frontend mein API calls kahan par hongi
# Development: http://localhost:8000
# Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:8000

# API request timeout (milliseconds)
# Agar API 30 seconds mein respond nahi de to error
VITE_API_TIMEOUT=30000

# =====================================================
# 8. OPTIONAL - ADVANCED CONFIGURATION
# =====================================================

# Database pool size (kitne connections ek saath ho sakti hain)
# DB_POOL_SIZE=20

# Max requests (rate limiting ke liye)
# MAX_REQUESTS_PER_MINUTE=100

# Logging level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
